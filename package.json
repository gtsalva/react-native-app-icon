{
  "name": "react-native-app-icon",
  "version": "0.1.4",
  "description": "Generate iOS and Android app icons from a single source image",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "app-icon": "bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node bin/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ios",
    "android",
    "icons",
    "react-native",
    "app-icon"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtsalva/doicon.git"
  },
  "homepage": "https://github.com/gtsalva/doicon#readme",
  "bugs": {
    "url": "https://github.com/gtsalva/doicon/issues"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "culori": "^4.0.2",
    "sharp": "^0.33.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
